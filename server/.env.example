# Daikin Onecta credentials from https://developer.cloud.daikineurope.com/
# Copy this file to server/.env and fill in your values. Do NOT commit .env.
DAIKIN_CLIENT_ID=your-client-id
DAIKIN_CLIENT_SECRET=your-client-secret

# Must EXACTLY match a redirect URI registered for your app in the Daikin portal.
# Local dev:
DAIKIN_REDIRECT_URI=http://localhost:3001/api/daikin/auth/callback
# Production (Hetzner) example:
# DAIKIN_REDIRECT_URI=https://smarthome.example.com/api/daikin/auth/callback

PORT=3001
